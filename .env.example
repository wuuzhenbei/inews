# AI API配置（支持所有 OpenAI 兼容的模型）
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://api.siliconflow.cn/v1
AI_MODEL=Qwen/Qwen2.5-7B-Instruct
AI_CHAT_MODEL=  # 聊天专用模型（更快），留空则用AI_MODEL

# 其他模型配置示例：
# DeepSeek V3:  AI_BASE_URL=https://api.deepseek.com/v1  AI_MODEL=deepseek-chat
# DeepSeek R1:  AI_BASE_URL=https://api.deepseek.com/v1  AI_MODEL=deepseek-reasoner
# 通义千问:     AI_BASE_URL=https://api.siliconflow.cn/v1  AI_MODEL=Qwen/Qwen2.5-72B-Instruct
# 小米MiMo:    AI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1  AI_MODEL=mimo-v2.5
# 月之暗面:     AI_BASE_URL=https://api.moonshot.cn/v1  AI_MODEL=moonshot-v1-8k
# 智谱:        AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4  AI_MODEL=glm-4-flash

# X/Twitter Bearer Token
X_BEARER_TOKEN=your-bearer-token-here

# RSSHub实例地址
RSSHUB_BASE=http://localhost:1200

# API访问密钥（留空则不限制）
API_ACCESS_KEY=
